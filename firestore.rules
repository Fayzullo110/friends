rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow users to read/write their own data
  	match /users/{userId} {
  // allow reading user profiles + searching
  allow get, list: if request.auth != null;

  // allow creating own profile (signup)
  allow create: if request.auth != null;

  // allow editing own profile
  allow update, delete: if request.auth != null;
}

    // Allow authenticated users to create stories
    match /stories/{storyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == resource.data.authorId;
    }

    // Allow authenticated users to create/view comments
    match /storyComments/{commentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == resource.data.authorId;
    }

    // Allow users to read/write their own status
    match /userStatuses/{statusId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Allow users to read/write follows
    match /follows/{followId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Allow users to read/write chats they're members of
    match /chats/{chatId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.members;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid in resource.data.members;
    }

    // Allow users to read/write messages in chats they're members of
    match /chatMessages/{messageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == resource.data.senderId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.senderId;
    }

    // Allow users to read/write chat participants
    match /chatParticipants/{participantId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Allow users to read/write reactions
    match /chatReactions/{reactionId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Allow users to read/write notifications
    match /notifications/{notificationId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.recipientId;
      allow write: if request.auth != null;
    }

    // Allow users to read/write posts
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == resource.data.authorId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.authorId;
    }

    // Allow users to read/write reels
    match /reels/{reelId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == resource.data.authorId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.authorId;
    }

    // Allow users to read/write likes
    match /likes/{likeId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Allow users to read/write comments
    match /comments/{commentId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
